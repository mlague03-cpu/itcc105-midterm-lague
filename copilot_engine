class CopilotEngine {
  static String getResponse(String intent) {
    bool isInternetConnected = true;

    if (!isInternetConnected) {
      return "⚠️ You are offline. Please connect to the internet.";
    }

    intent = intent.toLowerCase();

    if (intent.contains("payment")) {
      return "💰 Your payment records are up to date.";
    } 
    else if (intent.contains("schedule")) {
      return "📅 Your class schedule is: Monday - ITCC 105, Tuesday - Math 101.";
    } 
    else if (intent.contains("enrollment")) {
      return "📋 Enrollment Help: Please visit the registrar or check requirements.";
    } 
    else if (intent.contains("hello") || intent.contains("hi")) {
      return "👋 Hello! How can I assist you today?";
    } 
    else {
      return "❓ Sorry, I didn't understand your request.";
    }
  }
}
